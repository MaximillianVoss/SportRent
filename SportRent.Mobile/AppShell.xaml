<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SportRent.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SportRent.Mobile"
    xmlns:pages="clr-namespace:SportRent.Mobile.Pages"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#163B2D"
    Shell.ForegroundColor="#F7F3EA"
    Shell.TitleColor="#F7F3EA"
    Title="SportRent">

    <TabBar
        Shell.TabBarBackgroundColor="#FCFAF6"
        Shell.TabBarForegroundColor="#163B2D"
        Shell.TabBarUnselectedColor="#7A847C"
        Shell.TabBarTitleColor="#163B2D">
        <ShellContent
            Title="Каталог"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="catalog" />

        <ShellContent
            Title="Заказы"
            ContentTemplate="{DataTemplate pages:OrdersPage}"
            Route="orders" />

        <ShellContent
            Title="Профиль"
            ContentTemplate="{DataTemplate pages:ProfilePage}"
            Route="profile" />
    </TabBar>

</Shell>
