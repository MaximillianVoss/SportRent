<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SportRent.Mobile.Models"
             xmlns:viewModels="clr-namespace:SportRent.Mobile.ViewModels"
             x:Class="SportRent.Mobile.Pages.EquipmentDetailsPage"
             x:DataType="viewModels:EquipmentDetailsPageViewModel"
             Title="{Binding Title}"
             BackgroundColor="#F3EEE4">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F3EB" Offset="0" />
            <GradientStop Color="#EDF3ED" Offset="0.5" />
            <GradientStop Color="#EEE5D7" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,20,20,28"
                                 Spacing="18">
                <Button Text="← Назад к каталогу"
                        Clicked="OnBackToCatalogClicked"
                        HorizontalOptions="Start"
                        BackgroundColor="#FCFAF6"
                        TextColor="#163B2D"
                        BorderColor="#D7D1C0"
                        BorderWidth="1"
                        CornerRadius="18"
                        Padding="14,8" />

                <Border BackgroundColor="{Binding AccentColor}"
                        Padding="20"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <Grid ColumnDefinitions="96,*"
                          ColumnSpacing="16">
                        <Border BackgroundColor="{Binding AccentSurfaceColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22"
                                HeightRequest="96"
                                WidthRequest="96">
                            <Grid>
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFill" />
                                <Label Text="{Binding SymbolText}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{Binding AccentColor}" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="6">
                            <Label Text="{Binding CategoryTitle}"
                                   FontSize="13"
                                   TextColor="#DCEDE2" />
                            <Label Text="{Binding Title}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   LineBreakMode="WordWrap" />
                            <Label Text="{Binding BrandModelText}"
                                   FontSize="14"
                                   TextColor="#F0F6F2" />
                            <Label Text="{Binding TypeTitle}"
                                   FontSize="13"
                                   TextColor="#CFE2D7" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            BackgroundColor="#FCFAF6"
                            Padding="16"
                            Stroke="#D7D1C0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Тариф от"
                                   FontSize="12"
                                   TextColor="#68726B" />
                            <Label Text="{Binding StartingPriceText}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#1B4332"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#FCFAF6"
                            Padding="16"
                            Stroke="#D7D1C0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Залог"
                                   FontSize="12"
                                   TextColor="#68726B" />
                            <Label Text="{Binding DepositText}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#3F403E"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border BackgroundColor="#FCFAF6"
                        Padding="16"
                        Stroke="#D7D1C0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 22">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Доступность"
                               FontSize="12"
                               TextColor="#68726B" />
                        <Label Text="{Binding AvailabilityText}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#283630" />
                        <Label Text="{Binding DescriptionText}"
                               FontSize="14"
                               TextColor="#59655F"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding HasError}"
                        BackgroundColor="#FFF1F0"
                        Padding="14"
                        Stroke="#E9A7A4"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#8C2F39"
                           LineBreakMode="WordWrap" />
                </Border>

                <VerticalStackLayout Spacing="10"
                                     IsVisible="{Binding HasRates}">
                    <Label Text="Тарифы"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#21342D" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rates}"
                                         Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:EquipmentRate">
                                <Border BackgroundColor="#FCFAF6"
                                        Padding="16"
                                        Stroke="#D7D1C0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 22">
                                    <Grid ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          ColumnSpacing="12"
                                          RowSpacing="4">
                                        <Label Text="{Binding RentalTypeTitle}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#24332D" />
                                        <Label Grid.Column="1"
                                               Text="{Binding DurationText}"
                                               FontSize="12"
                                               TextColor="#617069"
                                               VerticalOptions="Center" />
                                        <Label Grid.Row="1"
                                               Text="{Binding PriceText}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1B4332" />
                                        <Label Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding DepositText}"
                                               FontSize="13"
                                               TextColor="#5F564C" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10"
                                     IsVisible="{Binding HasRentalPoints}">
                    <Label Text="Пункты проката"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#21342D" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding RentalPoints}"
                                         Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:RentalPointAvailability">
                                <Border BackgroundColor="#FCFAF6"
                                        Padding="16"
                                        Stroke="#D7D1C0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 22">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding RentalPointName}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#25322E" />
                                        <Label Text="{Binding Address}"
                                               FontSize="13"
                                               TextColor="#59655F"
                                               LineBreakMode="WordWrap" />
                                        <Label Text="{Binding MetaText}"
                                               FontSize="13"
                                               TextColor="#66716C" />
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <Label Text="{Binding PhoneText}"
                                                   FontSize="13"
                                                   TextColor="#45514B" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#F1EBDF"
                                                    Padding="10,6"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 16">
                                                <Label Text="{Binding AvailabilityText}"
                                                       FontSize="12"
                                                       TextColor="#534D45" />
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Button Text="Оформить аренду"
                        Clicked="OnCreateOrderClicked"
                        IsVisible="{Binding HasAvailableUnits}"
                        BackgroundColor="#163B2D"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="18,14" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#66F3EEE4">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="#163B2D"
                               HeightRequest="48"
                               WidthRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
